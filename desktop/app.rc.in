IDI_ICON1 ICON "@CMAKE_CURRENT_SOURCE_DIR@/assets/icon.ico"

1 VERSIONINFO
FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x40004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Jace Sleeman"
            VALUE "FileDescription", "PsPixel - Professional Pixel Art Editor"
            VALUE "FileVersion", "@PROJECT_VERSION@.0"
            VALUE "InternalName", "PsPixel"
            VALUE "LegalCopyright", "Copyright (c) 2026 Jace Sleeman"
            VALUE "OriginalFilename", "PsPixel.exe"
            VALUE "ProductName", "PsPixel"
            VALUE "ProductVersion", "@PROJECT_VERSION@.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
